NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Keep false for the dental office pilot. Create the user from Supabase Auth.
ALLOW_PUBLIC_SIGNUP=false

# Required only when a secured scheduled reminder processor is configured.
CRON_SECRET=

# Required for SMS reminders through Vonage.
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM=RemindMeUp

# Optional legacy email reminder settings.
RESEND_API_KEY=
REMINDER_FROM_EMAIL=
